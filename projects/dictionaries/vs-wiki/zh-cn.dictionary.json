  "modifiers": {
    "cooked": {
      "translation": "熟的",
      "template": "{term}"
    },
    "chopped": {
      "translation": "切碎的",
      "template": "{term}碎"
    },
    "salted": {
      "translation": "腌",
      "template": "{modifier}{term}"
    },
    "charred": {
      "translation": "烧焦的",
      "template": "{term}{modifier}"
    }
  },
  "aliases": {
    "pickled": "salted",
    "undercooked": "part-baked",
    "half-baked": "part-baked"
  },
  "templates": {
    "default": "{modifier}{term}",
    "part-baked": "{term}{modifier}",
    "charred": "{term}{modifier}"
  },
  "transforms": [
    {
      "id": "chopped",
      "regex": "切碎的(.+)",
      "replacement": "$1碎"
    },
    {
      "id": "cooked",
      "regex": "(.*?的)熟的",
      "replacement": "$1"
    }
  ],
  "exceptions": {}
}